# NurseAda - copy to .env and fill in values

# API Gateway (web + mobile call this)
# Use 8080 when running start-dev-all.ps1; use 8000 for docker-compose
NEXT_PUBLIC_GATEWAY_URL=your_gateway_url
EXPO_PUBLIC_GATEWAY_URL=http://localhost:8080


# USSD bridge (points at gateway)
GATEWAY_URL=your_gateway_url

# Gateway → backend services (use these in gateway env)
GATEWAY_FHIR_URL=your_fhir_url
GATEWAY_LLM_URL=your_llm_url
GATEWAY_CDSS_URL=your_cdss_url
GATEWAY_KNOWLEDGE_URL=your_knowledge_url
PHARMACY_API_URL=your_pharmacy_url
LAB_API_URL=your_lab_url
EMERGENCY_API_URL=your_emergency_url
GATEWAY_XAI_URL=your_xai_url

# FHIR adapter → upstream FHIR server (EHR)
# Per HL7 FHIR spec (https://fhir.hl7.org/fhir/index.html): REST API + Patient, Observation, MedicationRequest, Task, etc.
# Public test server (R4) – do not use for production or real PHI: https://hapi.fhir.org/baseR4
FHIR_BASE_URL=your_fhir_base_url

# LLM (OpenAI-compatible or Claude)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
# Vision model for medical image analysis (default: gpt-4o)
VISION_MODEL=your_vision_model
# Text completion model (default: gpt-4o)
COMPLETION_MODEL=your_completion_model

# Vector DB (e.g. Pinecone)
VECTOR_DB_API_KEY=your_vector_db_api_key
VECTOR_DB_ENVIRONMENT=your_vector_db_environment

# Pinecone (recommendation engine, semantic search)
# Use same key as VECTOR_DB_API_KEY when using Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index

# Supabase Auth (required for authentication)
# Create a project at https://supabase.com/dashboard and copy these values.
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=
# Service role key for server-side Supabase access (medication reminders, etc.)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Web app (Next.js) — same Supabase project, browser-safe keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Fallback locale for next-intl (avoids ENVIRONMENT_FALLBACK during build). Use: en, pcm, ha, yo, ig.
NEXT_PUBLIC_LOCALE=your_locale

# Mobile app (Expo) — same Supabase project
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: analytics
# AMPLITUDE_API_KEY=your_amplitude_api_key
# MIXPANEL_TOKEN=your_mixpanel_token

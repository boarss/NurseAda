# NurseAda - copy to .env and fill in values

# API Gateway (web + mobile call this)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
EXPO_PUBLIC_GATEWAY_URL=http://localhost:8000

# USSD bridge (points at gateway)
GATEWAY_URL=http://localhost:8000

# Gateway → backend services (use these in gateway env)
GATEWAY_FHIR_URL=http://localhost:8011
GATEWAY_LLM_URL=http://localhost:8001
GATEWAY_CDSS_URL=http://localhost:8002
GATEWAY_KNOWLEDGE_URL=http://localhost:8003
PHARMACY_API_URL=
LAB_API_URL=
EMERGENCY_API_URL=

# FHIR adapter → upstream FHIR server (EHR)
# Per HL7 FHIR spec (https://fhir.hl7.org/fhir/index.html): REST API + Patient, Observation, MedicationRequest, Task, etc.
# Public test server (R4) – do not use for production or real PHI: https://hapi.fhir.org/baseR4
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# LLM (OpenAI-compatible or Claude)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Vector DB (e.g. Pinecone)
VECTOR_DB_API_KEY=
VECTOR_DB_ENVIRONMENT=

# Auth (e.g. Firebase / JWT secret)
JWT_SECRET=
# FIREBASE_* if using Firebase Auth

# Optional: analytics
# AMPLITUDE_API_KEY=
# MIXPANEL_TOKEN=

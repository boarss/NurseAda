{
  "expo": {
    "name": "NurseAda",
    "slug": "nurseada",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nurseada",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nurseada.app"
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#059669" },
      "package": "com.nurseada.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}

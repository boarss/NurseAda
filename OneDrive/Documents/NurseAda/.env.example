NURSEADA_ENV=dev

# Public-facing apps
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Service URLs (internal dev)
GATEWAY_PORT=8000
LLM_GATEWAY_URL=http://localhost:8001
CDSS_URL=http://localhost:8002
KNOWLEDGE_URL=http://localhost:8003

# LLM Gateway configuration
# Choose one: openai_compat | openai | anthropic
LLM_PROVIDER=openai_compat

# For self-hosted / OpenAI-compatible servers (vLLM, LM Studio, Ollama w/ OpenAI compat)
OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
OPENAI_COMPAT_API_KEY=local-dev
OPENAI_COMPAT_MODEL=llama3.1

# Hosted providers (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Data stores (future wiring)
POSTGRES_URL=postgresql://nurseada:nurseada@localhost:5432/nurseada
MONGODB_URL=mongodb://localhost:27017/nurseada
REDIS_URL=redis://localhost:6379/0


{
  "name": "nurseada",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered 24/7 virtual healthcare assistant for primary care (Nigeria & Africa)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "pinecone:recommendations": "npx tsx scripts/pinecone-recommendations.ts",
    "dev": "npm run dev --workspace=apps/web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test:backend": "pytest services/gateway/tests services/cdss/tests services/fhir-adapter/tests",
    "test:web": "npm test --workspace=apps/web",
    "test:e2e": "npx playwright test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^7.1.0",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "@playwright/test": "^1.49.0"
  }
}

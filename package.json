{
  "name": "nurseada",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered 24/7 virtual healthcare assistant for primary care (Nigeria & Africa)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "pinecone:recommendations": "npx tsx scripts/pinecone-recommendations.ts",
    "dev": "npm run dev --workspace=apps/web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test:backend": "pytest services/cdss/tests -q && cd services/gateway && pytest tests -q && cd ../fhir-adapter && pytest tests -q",
    "test:web": "npm test --workspace=apps/web",
    "test:mobile": "npm test --workspace=nurseada-mobile",
    "test:mobile:integration": "npm run test:integration --workspace=nurseada-mobile",
    "test:e2e": "npx playwright test"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^7.1.0",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.0"
  }
}

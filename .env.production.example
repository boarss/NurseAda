# NurseAda Production – copy to .env and fill in values
# Use this template when deploying to Render, Vercel, EAS, etc.

# ── Public URLs (clients call these) ───────────────────────────────────
# Web app (Vercel): set in Vercel project → Settings → Environment Variables
NEXT_PUBLIC_GATEWAY_URL=https://nurseada-gateway.onrender.com

# Mobile app (EAS): set per build profile in eas.json env
EXPO_PUBLIC_GATEWAY_URL=https://api.nurseada.com

# ── Gateway CORS (comma-separated allowed origins) ───────────────────
# Must include your Vercel domain and any custom domains
CORS_ALLOW_ORIGINS=https://nurseada.vercel.app,https://nurseada.com,https://www.nurseada.com

# ── Backend service URLs (Render internal DNS) ─────────────────────────
# For docker-compose production or Render blueprint
GATEWAY_FHIR_URL=http://nurseada-fhir-adapter:8011
GATEWAY_LLM_URL=http://nurseada-llm-gateway:8001
GATEWAY_CDSS_URL=http://nurseada-cdss:8002
GATEWAY_KNOWLEDGE_URL=http://nurseada-knowledge:8003
GATEWAY_XAI_URL=http://nurseada-xai:8012
PHARMACY_API_URL=
LAB_API_URL=
EMERGENCY_API_URL=

# USSD bridge
GATEWAY_URL=http://nurseada-gateway:8000

# ── FHIR server (EHR) ─────────────────────────────────────────────────
FHIR_BASE_URL=https://your-fhir-server.example.com/fhir/r4

# ── LLM (required for chat and vision) ───────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
VISION_MODEL=gpt-4o
COMPLETION_MODEL=gpt-4o

# ── Vector DB (optional, for RAG) ────────────────────────────────────
VECTOR_DB_API_KEY=
VECTOR_DB_ENVIRONMENT=

# ── Supabase Auth (required for auth) ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web app (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Fallback locale for next-intl (avoids ENVIRONMENT_FALLBACK during build)
NEXT_PUBLIC_LOCALE=en

# Mobile app (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Optional: analytics ──────────────────────────────────────────────
# AMPLITUDE_API_KEY=
# MIXPANEL_TOKEN=
